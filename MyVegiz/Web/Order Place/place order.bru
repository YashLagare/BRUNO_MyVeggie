meta {
  name: place order
  type: http
  seq: 1
}

post {
  url: {{base_url2}}/web/orders/place
  body: json
  auth: bearer
}

params:query {
  ~lat: 16.695083374702104
  ~lng: 74.20434800272267
}

auth:bearer {
  token: {{web_access_token}}
}

body:json {
  {
    "payment_mode": "COD",
    "address_uu_id": "de195712-5660-45bc-a26c-1e8d2974794e",
    "customer_note": "Please deliver fast"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
