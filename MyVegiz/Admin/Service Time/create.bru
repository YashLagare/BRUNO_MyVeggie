meta {
  name: create
  type: http
  seq: 1
}

post {
  url: {{base_url2}}/admin/service/time/create
  body: formUrlEncoded
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:form-urlencoded {
  service_start_time: 15:00
  service_end_time: 20:00
  is_active: true
}

settings {
  encodeUrl: true
  timeout: 0
}
