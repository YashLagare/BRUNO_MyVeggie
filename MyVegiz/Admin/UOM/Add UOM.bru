meta {
  name: Add UOM
  type: http
  seq: 2
}

post {
  url: {{base_url2}}/admin/uoms/create
  body: formUrlEncoded
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:form-urlencoded {
  uom_name: KG
  uom_short_name: kilo gram
  ~description: 
}

settings {
  encodeUrl: true
  timeout: 0
}
