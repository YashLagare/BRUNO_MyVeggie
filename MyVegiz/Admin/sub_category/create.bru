meta {
  name: create
  type: http
  seq: 1
}

post {
  url: {{base_url2}}/admin/sub-categories/create
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:multipart-form {
  category_id: 33
  sub_category_name: Organic vabc
  sub_category_image: @file(C:\Users\Admin\Downloads\Archery.png)
}

settings {
  encodeUrl: true
  timeout: 0
}
