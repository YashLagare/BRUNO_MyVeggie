meta {
  name: update
  type: http
  seq: 4
}

put {
  url: {{base_url2}}/admin/zone/update?zone_id=28
  body: multipartForm
  auth: bearer
}

params:query {
  zone_id: 28
}

auth:bearer {
  token: {{access_token}}
}

