meta {
  name: create
  type: http
  seq: 1
}

post {
  url: {{base_url2}}/admin/entitycategory/create
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:multipart-form {
  entity_category: Restaurant
  main_category_id: 12
}

settings {
  encodeUrl: true
  timeout: 0
}
