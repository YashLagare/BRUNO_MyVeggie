meta {
  name: create
  type: http
  seq: 1
}

post {
  url: {{base_url2}}/admin/slot/create
  body: formUrlEncoded
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:form-urlencoded {
  start_time: 15:00
  end_time: 16:00
  is_active: true
}

settings {
  encodeUrl: true
  timeout: 0
}
