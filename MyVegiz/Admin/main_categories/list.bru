meta {
  name: list
  type: http
  seq: 1
}

get {
  url: {{base_url2}}/admin/main-categories/list?page =2&limit=10&q=Grocery
  body: none
  auth: bearer
}

params:query {
  "page ": 2
  limit: 10
  q: Grocery
}

auth:bearer {
  token: {{access_token}}
}

settings {
  encodeUrl: true
  timeout: 0
}
