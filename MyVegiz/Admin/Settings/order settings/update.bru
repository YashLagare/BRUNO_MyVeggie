meta {
  name: update
  type: http
  seq: 3
}

put {
  url: {{base_url2}}/admin/order/settings
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:multipart-form {
  is_cod_enabled: true
  is_online_enabled: true
  is_first_order_free: true
}

settings {
  encodeUrl: true
  timeout: 0
}
