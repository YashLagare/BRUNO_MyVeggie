meta {
  name: update
  type: http
  seq: 3
}

put {
  url: {{base_url2}}/admin/order/cancellation/settings
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:multipart-form {
  is_cancel_available: false
  cancellation_time: 15
}

settings {
  encodeUrl: true
  timeout: 0
}
