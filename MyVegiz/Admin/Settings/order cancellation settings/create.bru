meta {
  name: create
  type: http
  seq: 1
}

post {
  url: {{base_url2}}/admin/order/cancellation/settings
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:multipart-form {
  is_cancel_available: true
  ~cancellation_time: true
}

settings {
  encodeUrl: true
  timeout: 0
}
