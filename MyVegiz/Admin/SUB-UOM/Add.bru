meta {
  name: Add
  type: http
  seq: 2
}

post {
  url: {{base_url2}}/admin/sub_uom/create
  body: formUrlEncoded
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:form-urlencoded {
  uom_id: 23
  sub_uom_name: gram
  sub_uom_short_name: gram
  conversion_factor: 2
}

settings {
  encodeUrl: true
  timeout: 0
}
