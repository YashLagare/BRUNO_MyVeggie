meta {
  name: list
  type: http
  seq: 1
}

get {
  url: {{base_url2}}/delivery_boy/wallets?page=1&limit=10&wallet_type=TRANSACTION
  body: none
  auth: bearer
}

params:query {
  page: 1
  limit: 10
  wallet_type: TRANSACTION
}

auth:bearer {
  token: {{delivery_access_token}}
}

settings {
  encodeUrl: true
  timeout: 0
}
